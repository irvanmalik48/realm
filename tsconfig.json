{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "lodash": ["node_modules/es-toolkit/compat"],
      "lodash-es": ["node_modules/es-toolkit/compat"]
    }
  }
}
