---
import { ArrowDown } from "@lucide/astro";
import Container from "@/components/layouts/container.astro";
import DefaultContainer from "@/components/layouts/default-container.astro";
import { Button } from "@/components/ui/button";
import { cn } from "@/libs/helpers/cn";
---

<DefaultContainer>
  <!-- Quote Hero -->
  <Container
    containerId="hero"
    class={cn(
      "w-full min-h-screen mx-auto flex flex-col",
      "items-center justify-center bg-sidebar"
    )}
  >
    <div
      class={cn(
        "max-w-4xl w-full gap-5 flex flex-col",
        "items-center justify-center px-5 py-3"
      )}
    >
      <blockquote
        class={cn(
          "flex flex-col w-full items-center",
          "justify-center gap-5"
        )}
      >
        <p class={cn("md:text-4xl text-xl font-header")}>
          "And those who were seen dancing were thought to be
          <span class={cn("text-destructive")}>insane</span>
          by those who could not hear the music."
        </p>
        <footer
          class={cn(
            "md:text-xl text-muted-foreground",
            "w-full text-right"
          )}
        >
          &mdash; <cite>Friedrich Nietzsche</cite>
        </footer>
      </blockquote>
      <div class={cn("relative mt-5")}>
        <div
          class={cn(
            "absolute inset-0 rounded-full animate-ping",
            "bg-primary opacity-50"
          )}
        ></div>
        <Button
          as="a"
          href="#main-section"
          variant="solid"
          size="icon"
          class={cn("relative rounded-full!")}
        >
          <ArrowDown />
        </Button>
      </div>
    </div>
  </Container>

  <!-- Main Section -->
  <Container
    containerId="main-section"
    class={cn(
      "gap-5 w-full min-h-screen max-w-4xl mx-auto px-5 py-3",
      "flex flex-col items-center justify-center"
    )}
  >
    <h1 class={cn("text-4xl font-header")}>TBD</h1>
    <p class={cn("text-xl text-muted-foreground")}>
      I'm not sure what to put here yet.
    </p>
  </Container>
</DefaultContainer>
